@{
    ViewData["Title"] = "Create/Edit";
}

@model ExpenseTracking.Models.Expense

<div class="text-center">
    <h1 class="display-4">Create or Edit Expense</h1>
</div>

<form asp-action="CreateEditExpenseForm">
    <div class="mb-3">
        <input hidden asp-for="Id" class="form-control" type="number" placeholder="0"/>
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Value" class="form-label">Value($)</label>
        <input asp-for="Value" class="form-control" type="number" step="0.01" placeholder="0.00"/>
        <span asp-validation-for="Value" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <input asp-for="Description" class="form-control" type="text" placeholder="Enter description for expense."/>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>